# ============================================================
# briefing-auto-send configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
# Step 1: https://t.me/BotFather → send /newbot → follow prompts
# Step 2: https://t.me/userinfobot → send /start → note your numeric ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── SMTP (Gmail recommended) ──────────────────────────────────
# Google Account → Security → 2-Step Verification → App passwords
# Generate a 16-character app password (not your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com

# ── Schedule (used by briefing_runner.sh) ────────────────────
BRIEFING_TIMEZONE=America/New_York
BRIEFING_HOUR=13

# ── Behavior ─────────────────────────────────────────────────
FRIDAY_CODEX=true           # add --codex on Fridays (independent Codex second opinion)
SKIP_NON_TRADING_DAYS=true  # skip weekends + NYSE holidays
RETRY_MAX=3                 # max send retry attempts before error notification

# ── Macro snapshot (fetch_macro.py / FRED) ───────────────────
# Free API key (no credit card) at https://fred.stlouisfed.org/docs/api/api_key.html
# If left blank, macro snapshot is skipped and briefing falls back gracefully.
FRED_API_KEY=

# ── Earnings history (earnings_history.py) ───────────────────
# Optional override: comma-separated tickers when no journal exists yet
# Defaults to parsing tickers from the latest journal/YYYY-MM-DD.md
# EARNINGS_TICKERS=NVDA,AVGO,CRWD,MU

# ── EODHD fundamentals (fetch_fundamentals.py) ───────────────
# Get from https://eodhd.com/financial-apis/ → My API Tokens
EODHD_API_TOKEN=
# Optional override: comma-separated tickers when no journal exists yet
# FUNDAMENTALS_TICKERS=NVDA,AVGO,MU,CRWD,AMD
