<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fadacai.briefing</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/YOUR_USERNAME/path/to/portfolio/tools/briefing_runner.sh</string>
  </array>

  <!-- Single daily trigger at 17:00 system-local time. One attempt per day —
       no backup windows; if the run fails it only logs (no Discord error
       notify). Pair with `pmset repeat wakepoweron … 16:59 weekdays` and the
       com.fadacai.caffeinate agent so the Mac is awake for the window. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
  </array>

  <!-- TZ deliberately NOT set here: launchd then evaluates StartCalendarInterval
       in the system local timezone. ET timestamps are handled by
       briefing_runner.sh exporting TZ internally. -->
  <key>EnvironmentVariables</key>
  <dict>
    <!-- Add PATH so launchd can find python3 and claude CLI -->
    <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:/Users/YOUR_USERNAME/.local/bin</string>
    <key>HOME</key><string>/Users/YOUR_USERNAME</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USERNAME/path/to/portfolio/briefing-out/launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USERNAME/path/to/portfolio/briefing-out/launchd.err</string>

  <!-- Retry once if exit code is non-zero -->
  <key>ThrottleInterval</key>
  <integer>60</integer>

  <!-- Wake the Mac from sleep at scheduled time (requires AC power) -->
  <key>WakeForNetwork</key>
  <true/>
</dict>
</plist>
