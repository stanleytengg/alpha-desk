{
  "_comment": "Copy to .mcp.json and fill in your own paths + API tokens. .mcp.json is gitignored (contains secrets). Omit any server you don't use. coingecko is optional (crypto research); basic endpoints work without a key.",
  "mcpServers": {
    "technical": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "/abs/path/to/fadacai-mcp-servers/technical", "run", "server.py"]
    },
    "yfinance-advanced": {
      "type": "stdio",
      "command": "uvx",
      "args": ["yfinance-mcp"]
    },
    "polymarket-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["polymarket-mcp"]
    },
    "eodhd-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "/abs/path/to/fadacai-mcp-servers/eodhd", "run", "server.py"],
      "env": {
        "EODHD_API_TOKEN": "YOUR_EODHD_TOKEN_HERE"
      }
    },
    "sec-edgar-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["sec-edgar-mcp"],
      "env": {
        "SEC_EDGAR_USER_AGENT": "Your Name your@email.com"
      }
    },
    "fmp-mcp": {
      "type": "http",
      "url": "http://localhost:8081/mcp"
    },
    "coingecko": {
      "_comment": "Optional — crypto research via the official CoinGecko MCP (npm, run with npx; requires Node). Public/demo endpoints need no key; set COINGECKO_DEMO_API_KEY for higher rate limits (Demo plan is free). NOTE: tools/fetch_crypto.py already pulls CoinGecko REST without any MCP, so this server is fully optional.",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@coingecko/coingecko-mcp"],
      "env": {
        "COINGECKO_ENVIRONMENT": "demo"
      }
    }
  }
}
